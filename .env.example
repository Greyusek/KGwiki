# Runtime
NODE_ENV=development

# Auth.js / NextAuth
# Keep this aligned with how you access the app in Docker.
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret
AUTH_SECRET=replace-with-a-long-random-secret
AUTH_TRUST_HOST=true
NEXTAUTH_TRUST_HOST=true

# Database URL used by containers (docker-compose overrides to the same value for app service)
DATABASE_URL=postgresql://postgres:postgres@db:5432/kgwiki?schema=public

# MinIO local object storage
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
MINIO_BUCKET=kgwiki-local
